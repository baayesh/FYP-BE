{
  "info": {
    "name": "Teacher Dashboard API",
    "description": "API endpoints for teacher dashboard statistics",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Login as Teacher",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200) {",
              "    const response = pm.response.json();",
              "    if (response.success && response.data.access_token) {",
              "        pm.environment.set('teacher_token', response.data.access_token);",
              "        pm.environment.set('teacher_id', response.data.user.id);",
              "        console.log('Token saved to environment');",
              "    }",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"cara@teacher.example.com\",\n  \"password\": \"Test@1234\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/auth/login",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "auth", "login"]
        },
        "description": "Login to get Bearer token for authentication"
      },
      "response": []
    },
    {
      "name": "2. Get Dashboard Stats",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{teacher_token}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/v1/teacher/dashboard/stats",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "teacher", "dashboard", "stats"]
        },
        "description": "Get real-time dashboard statistics for the teacher:\n- Total courses\n- Total students\n- Pending grading count\n- Upcoming classes"
      },
      "response": []
    },
    {
      "name": "3. Capture Stats Snapshot",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{teacher_token}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/v1/teacher/dashboard/stats/snapshot",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "teacher", "dashboard", "stats", "snapshot"]
        },
        "description": "Capture and save today's statistics snapshot including:\n- All dashboard stats\n- Enrollments today\n- Submissions today\n- Saves to teacher_stats and teacher_stat_timeseries tables"
      },
      "response": []
    },
    {
      "name": "4. Get Teacher Courses by ID",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/v1/teacher/courses?teacher_id=11e8131c-64d3-46f3-88f3-7baec1d2b37f",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "teacher", "courses"],
          "query": [
            {
              "key": "teacher_id",
              "value": "11e8131c-64d3-46f3-88f3-7baec1d2b37f",
              "description": "UUID of the teacher whose courses to retrieve"
            }
          ]
        },
        "description": "Get all courses taught by a teacher specified by UUID:\n- Returns course details with enrollment counts\n- Optional status filter: ?status=active|archived|draft\n- No authentication required"
      },
      "response": []
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000",
      "type": "string"
    }
  ]
}
